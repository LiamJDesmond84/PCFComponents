<?xml version="1.0" encoding="utf-8" ?>
<manifest>
  <control
    namespace="PCFGraphNS"
    constructor="PCFGraph"
    version="0.0.5"
    display-name-key="PCFGraph"
    description-key="PCFGraph description"
    control-type="standard">

    <external-service-usage enabled="false">
    </external-service-usage>

    <property
      name="hostValue"
      display-name-key="Host Value"
      description-key="Host field used to place the control on a form"
      of-type="SingleLine.Text"
      usage="bound"
      required="true" />

    <property
      name="chartTitle"
      display-name-key="Chart Title"
      description-key="Optional chart title"
      of-type="SingleLine.Text"
      usage="input"
      required="false" />

    <resources>
      <code path="index.ts" order="1" />
    </resources>

    <feature-usage>
      <uses-feature name="WebAPI" required="true" />
    </feature-usage>
  </control>
</manifest>